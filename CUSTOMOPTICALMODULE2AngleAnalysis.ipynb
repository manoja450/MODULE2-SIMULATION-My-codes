# %% [markdown]
# # Tyvek Reflectivity Analysis - Thesis Style Plots with Gaussian + Lambertian Fits
# ## Direct comparison with Chavarria Thesis (2007) Figures 42-50

# %%
import uproot
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy.optimize import curve_fit
import glob
import os
import warnings
warnings.filterwarnings('ignore')

# Set style for thesis-quality plots
plt.rcParams['figure.figsize'] = (12, 10)
plt.rcParams['font.size'] = 14
plt.rcParams['axes.labelsize'] = 16
plt.rcParams['axes.titlesize'] = 18
plt.rcParams['xtick.labelsize'] = 12
plt.rcParams['ytick.labelsize'] = 12
plt.rcParams['legend.fontsize'] = 12
plt.rcParams['lines.linewidth'] = 2
plt.rcParams['axes.grid'] = True
plt.rcParams['grid.alpha'] = 0.3
plt.rcParams['grid.linestyle'] = '--'

# Define the Gaussian + Lambertian fit function
def gaussian_lambertian(theta, p1, p2, p3, p4):
    """
    f = p1 * cos(theta) + p2 * exp(-(theta - p3)^2 / (2 * p4^2))
    p1: Lambertian amplitude
    p2: Gaussian amplitude
    p3: Gaussian center (expected at -phi)
    p4: Gaussian spread (sigma)
    """
    return p1 * np.cos(np.radians(theta)) + p2 * np.exp(-(theta - p3)**2 / (2 * p4**2))

# %% [markdown]
# ### 1. Set the ROOT File Path

# %%
# ============================================================
# EDIT THIS LINE TO CHANGE THE INPUT FILE
# ============================================================
root_file_path = "Sim_D2ODetector011.root"
# ============================================================

# Verify file exists
if not os.path.exists(root_file_path):
    print(f"ERROR: File '{root_file_path}' not found!")
    print("Available ROOT files in current directory:")
    root_files = glob.glob("Sim_D2ODetector*.root")
    for f in root_files:
        file_size = os.path.getsize(f) / (1024 * 1024)
        print(f"  - {f} ({file_size:.2f} MB)")
    df = pd.DataFrame()
else:
    file_size = os.path.getsize(root_file_path) / (1024 * 1024)
    print(f"Loading file: {root_file_path} ({file_size:.2f} MB)")
    root_file = uproot.open(root_file_path)
    
    # Get reflections tree
    if "ReflectionTree" in root_file:
        df = root_file["ReflectionTree"].arrays(["incident_angle", "reflected_angle", "event_id"], library="pd")
        
        # Rename columns for consistency
        df.rename(columns={
            'incident_angle': 'incidentAngle_deg',
            'reflected_angle': 'reflectionAngle_deg',
            'event_id': 'eventID'
        }, inplace=True)
        
        print(f"Loaded {len(df)} reflections from {df['eventID'].nunique()} events")
        print(f"Incident angle range: {df['incidentAngle_deg'].min():.1f}° to {df['incidentAngle_deg'].max():.1f}°")
        print(f"Reflection angle range: {df['reflectionAngle_deg'].min():.1f}° to {df['reflectionAngle_deg'].max():.1f}°")
    else:
        print("No 'ReflectionTree' found!")
        print(f"Available trees: {[key for key in root_file.keys() if hasattr(root_file[key], 'keys')]}")
        df = pd.DataFrame()

# %% [markdown]
# ### 2. Create Point Plots with Visible Error Bars and Legend

# %%
if len(df) > 0:
    # Define target incident angles
    target_angles = [0, 10, 20, 30, 40, 50, 60, 70, 80]
    tolerance = 3  # degrees tolerance for binning
    bin_size = 5  # Fixed bin size of 5 degrees
    
    # Create figure with 9 subplots
    fig, axes = plt.subplots(3, 3, figsize=(18, 15))
    axes = axes.flatten()
    
    print(f"\n=== Generating Thesis-Style Plots with Visible Error Bars ===")
    print(f"File: {os.path.basename(root_file_path)}")
    print(f"Bin size: {bin_size}°\n")
    
    # Store fit results for ratio table
    fit_results = []
    
    for idx, phi_target in enumerate(target_angles):
        # Select events with incident angle near target
        mask = np.abs(df['incidentAngle_deg'] - phi_target) <= tolerance
        data_bin = df[mask]
        
        if len(data_bin) > 0:
            # Get reflection angles
            reflection_angles = data_bin['reflectionAngle_deg'].values
            
            # Get data range
            data_min = reflection_angles.min()
            data_max = reflection_angles.max()
            
            # Set x-axis limits (add small margin)
            margin = 5
            x_min = data_min - margin
            x_max = data_max + margin
            
            # Create histogram
            n_bins = int(np.ceil((x_max - x_min) / bin_size))
            hist, bin_edges = np.histogram(reflection_angles, bins=n_bins, range=(x_min, x_max))
            bin_centers = (bin_edges[:-1] + bin_edges[1:]) / 2
            
            # Normalize by bin width
            hist_normalized = hist / bin_size
            
            # Calculate Poisson errors (sqrt(N) / bin_width)
            hist_errors = np.sqrt(hist) / bin_size
            
            # Make error bars more visible: set minimum relative error of 3%
            relative_error = hist_errors / hist_normalized
            min_relative_error = 0.03  # 3% minimum error
            for i in range(len(hist_errors)):
                if hist_normalized[i] > 0:
                    if relative_error[i] < min_relative_error:
                        hist_errors[i] = hist_normalized[i] * min_relative_error
                else:
                    # For zero bins, use 5% of max value as error
                    if len(hist_normalized) > 0:
                        max_val = np.max(hist_normalized)
                        hist_errors[i] = max_val * 0.05
            
            # Perform Gaussian + Lambertian fit
            initial_guess = [np.max(hist_normalized) * 0.5, 
                           np.max(hist_normalized) * 0.5, 
                           -phi_target, 30.0]
            
            lower_bounds = [0, 0, -phi_target - 10, 5]
            upper_bounds = [np.inf, np.inf, -phi_target + 10, 60]
            
            try:
                fit_mask = hist_normalized > 0
                popt, pcov = curve_fit(gaussian_lambertian, 
                                       bin_centers[fit_mask], 
                                       hist_normalized[fit_mask],
                                       p0=initial_guess,
                                       bounds=(lower_bounds, upper_bounds))
                
                p1, p2, p3, p4 = popt
                perr = np.sqrt(np.diag(pcov))
                ratio = p2 / p1
                
                fit_results.append({
                    'phi': phi_target,
                    'p1': p1, 'p1_err': perr[0],
                    'p2': p2, 'p2_err': perr[1],
                    'p3': p3, 'p3_err': perr[2],
                    'p4': p4, 'p4_err': perr[3],
                    'ratio': ratio
                })
                
                # Generate smooth fit curve
                theta_fit = np.linspace(x_min, x_max, 200)
                fit_curve = gaussian_lambertian(theta_fit, p1, p2, p3, p4)
                
                print(f"φ = {phi_target:2d}°: p1={p1:.3f}, p2={p2:.3f}, p3={p3:.1f}°, p4={p4:.1f}°, Ratio={ratio:.3f}")
                
            except Exception as e:
                print(f"φ = {phi_target:2d}°: Fit failed - {e}")
                p1, p2, p3, p4 = initial_guess
                ratio = p2 / p1
                theta_fit = np.linspace(x_min, x_max, 200)
                fit_curve = gaussian_lambertian(theta_fit, *initial_guess)
                fit_results.append({
                    'phi': phi_target,
                    'p1': p1, 'p1_err': 0,
                    'p2': p2, 'p2_err': 0,
                    'p3': p3, 'p3_err': 0,
                    'p4': p4, 'p4_err': 0,
                    'ratio': ratio
                })
            
            # Plot data points with visible error bars
            axes[idx].errorbar(bin_centers, hist_normalized, yerr=hist_errors,
                             fmt='o', color='blue', markersize=5, 
                             capsize=0, elinewidth=2, alpha=0.8, 
                             ecolor='black', label='Data')
            
            # Plot fit curve
            axes[idx].plot(theta_fit, fit_curve, 'r-', linewidth=2.5, 
                          label='Gaussian + Lambertian fit')
            
            # Formatting
            axes[idx].set_xlabel('Reflection Angle (degrees)', fontsize=14, fontweight='semibold')
            axes[idx].set_ylabel(f'Counts/{bin_size} degrees', fontsize=14, fontweight='semibold')
            axes[idx].set_title(f'Incident Angle = {phi_target}°', fontsize=16, fontweight='bold')
            axes[idx].set_xlim(x_min, x_max)
            axes[idx].set_ylim(bottom=0)
            axes[idx].grid(True, alpha=0.3, linestyle='--')
            axes[idx].legend(loc='upper right', fontsize=10)
            
        else:
            axes[idx].text(0.5, 0.5, f'No data for {phi_target}°', 
                          transform=axes[idx].transAxes, ha='center', va='center', fontsize=14)
            axes[idx].set_title(f'Incident Angle = {phi_target}°', fontsize=16, fontweight='bold')
            axes[idx].set_xlabel('Reflection Angle (degrees)', fontsize=14, fontweight='semibold')
            axes[idx].set_ylabel(f'Counts/{bin_size} degrees', fontsize=14, fontweight='semibold')
            axes[idx].set_xlim(-80, 80)
            axes[idx].set_ylim(0, 1)
            print(f"φ = {phi_target:2d}°: NO DATA")
    
    # Add main title
    plt.suptitle(f'Tyvek Reflectivity - Simulation Results\n{os.path.basename(root_file_path)}', 
                fontsize=20, fontweight='bold', y=0.98)
    plt.tight_layout()
    
    # Save the plot
    file_prefix = os.path.splitext(os.path.basename(root_file_path))[0]
    output_filename = f'{file_prefix}_final_plots_with_legend.png'
    plt.savefig(output_filename, dpi=150, bbox_inches='tight')
    plt.show()
    print(f"\n✓ Plot saved as: {output_filename}")

# %% [markdown]
# ### 3. Thesis-Style Table (Page 41) - Ratio of Gaussian/Lambertian Components

# %%
if len(fit_results) > 0:
    # Thesis data from page 41 (Φ₂/Φ_L ratio)
    thesis_data = {
        0: 0.93,
        10: 1.26,
        20: 0.859,
        30: 0.375,
        40: 0.517,
        50: 0.527,
        60: 0.643,
        70: 0.963,
        80: 1.26
    }
    
    print("\n" + "="*90)
    print("TABLE: Ratio of Gaussian/Lambertian Components (Φ₂/Φₗ)")
    print("="*90)
    print(f"{'Angle of incidence φ':^25} {'Simulation':^20} {'Thesis':^20}")
    print("-"*65)
    
    for result in fit_results:
        phi = result['phi']
        sim_ratio = result['ratio']
        thesis_val = thesis_data.get(phi, 0)
        
        print(f"{phi:^25}° {sim_ratio:^20.3f} {thesis_val:^20.3f}")
    
    print("="*90)
    
    # Print exactly as thesis format
    print("\n" + "="*90)
    print("THESIS-STYLE TABLE (as on page 41)")
    print("="*90)
    print("\nRatio of Gaussian/Lambertian components: Φ₂/Φₗ")
    print("-"*70)
    print(f"{'Angle of incidence (φ)':^30} {'Φ₂/Φₗ':^20}")
    print("-"*70)
    
    for result in fit_results:
        phi = result['phi']
        sim_ratio = result['ratio']
        print(f"{phi:^30}° {sim_ratio:^20.3f}")
    
    print("-"*70)
    print("="*90)

# %% [markdown]
# ### 4. Comparison Plot with Thesis Data

# %%
if len(fit_results) > 0:
    # Create comparison plot
    fig, ax = plt.subplots(figsize=(10, 7))
    
    # Extract data for plotting
    angles_sim = [r['phi'] for r in fit_results]
    ratios_sim = [r['ratio'] for r in fit_results]
    
    # Thesis data
    angles_thesis = list(thesis_data.keys())
    ratios_thesis = list(thesis_data.values())
    
    # Plot simulation
    ax.plot(angles_sim, ratios_sim, 'o-', color='blue', markersize=8, linewidth=2,
           label='Simulation (Data-Driven Reflector)')
    
    # Plot thesis data
    ax.plot(angles_thesis, ratios_thesis, 's-', color='red', markersize=8, linewidth=2,
           label='Thesis Data (Chavarria 2007)')
    
    # Formatting
    ax.set_xlabel('Angle of Incidence φ (degrees)', fontsize=14, fontweight='semibold')
    ax.set_ylabel('Φ₂/Φₗ (Gaussian/Lambertian Ratio)', fontsize=14, fontweight='semibold')
    ax.set_title('Comparison of Gaussian/Lambertian Component Ratios', fontsize=16, fontweight='bold')
    ax.legend(fontsize=11)
    ax.grid(True, alpha=0.3, linestyle='--')
    ax.set_xlim(-2, 82)
    y_max = max(max(ratios_sim), max(ratios_thesis)) * 1.1
    ax.set_ylim(bottom=0, top=y_max)
    
    # Add horizontal line at y=1 for reference
    ax.axhline(y=1, linestyle=':', linewidth=1.5, color='gray', alpha=0.7)
    
    plt.tight_layout()
    
    # Save comparison plot
    comparison_filename = f'{file_prefix}_ratio_comparison.png'
    plt.savefig(comparison_filename, dpi=150, bbox_inches='tight')
    plt.show()
    print(f"\n✓ Comparison plot saved as: {comparison_filename}")

# %% [markdown]
# ### 5. Analysis Complete

# %%
if len(df) > 0:
    print("\n" + "="*60)
    print("ANALYSIS COMPLETE")
    print("="*60)
    print(f"Input file: {root_file_path}")
    print(f"Total reflections analyzed: {len(df):,}")
    print(f"Plot saved: {output_filename}")
    print(f"Comparison plot saved: {comparison_filename}")
    print(f"Fit function: p₁·cos(θ) + p₂·exp(-(θ-p₃)²/(2p₄²))")
    print(f"Bin size: {bin_size}°")
    print("="*60)
else:
    print("\n" + "="*60)
    print("NO DATA TO ANALYZE")
    print("="*60)
